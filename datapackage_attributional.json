{
    "profile": "data-package",
    "name": "hydrogen-production-scenarios-2035",
    "title": "prospective Life Cycle Assessment of French Hydrogen Production on the 2035 time horizon",
    "description": "Generates prospective LCA databases for hydrogen production in France. RTE scenarios from 'Futurs energetiques 2050' has been added to refine the electricty mix",
    "contributors":[
        {
        "title": "François-Xavier Dézert",
        "email": "francois-xavier.dezert@ifpen.fr"
        },
        {
        "title": "Guillaume Batôt",
        "email": "guillaume.batot@ifpen.fr"
        }
    ],
    "dependencies": {
        "premise": ">=2.2.4"
    },
    "ecoinvent": {
        "version": "3.11",
        "system model": "cut-off"
    },
    "scenarios": {
